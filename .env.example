# ──────────────────────────────────────────────────────────────
#  21MG 대시보드 환경변수 — 이 파일(.env.example)만 커밋.
#  실제 값은 .env.local 에 복사해 채우세요. (.env.local 은 .gitignore)
#  배포 시에는 GitHub Actions Secrets 에 같은 이름으로 등록.
# ──────────────────────────────────────────────────────────────

# Firebase 웹앱 config (콘솔 > 프로젝트 설정 > 웹앱).
#  ※ 웹 API 키는 "비밀"이 아님 — 공개돼도 됨. 보안은 Firestore 규칙으로.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 편집 모드 PIN (숫자 권장).
#  ⚠️ 클라이언트 UX 게이트일 뿐 보안이 아님. 코드에 평문 금지 — 반드시 env.
#  TEAM ≠ ADMIN 으로 서로 다르게.
VITE_TEAM_PIN=      # 팀장 공유: 바자회·To-Do·팀 체크/메모
VITE_ADMIN_PIN=     # 관리자 전용(이영천·신나희·전선희): 위 + 후원·공지

# 행사 종료 후 보관 모드. true 면 동적 섹션을 스냅샷(archive)으로 동결.
VITE_ARCHIVED=false
