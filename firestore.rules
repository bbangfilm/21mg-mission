rules_version = '2';
// 21MG 대시보드 — 동적 컬렉션만 Firestore 사용(정적 데이터는 앱 src/data).
// 읽기: 누구나(링크 공유형). 쓰기: 익명 로그인 + 타입/길이 검증.
// ⚠️ PIN은 클라이언트 UX 게이트일 뿐 — 규칙은 "인증된 누구나 + 스키마 검증"까지만(1회용·신뢰그룹 전제).
service cloud.firestore {
  match /databases/{database}/documents {
    function signed() { return request.auth != null; }

    // 후원 현황 (관리자 편집)
    match /config/sponsorship {
      allow read: if true;
      allow write: if signed()
        && request.resource.data.goalAmount is number && request.resource.data.goalAmount >= 0
        && request.resource.data.currentAmount is number && request.resource.data.currentAmount >= 0;
    }

    // 이번 주 할 일
    match /todos/{id} {
      allow read: if true;
      allow create, update: if signed()
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0 && request.resource.data.text.size() < 300;
      allow delete: if signed();
    }

    // 바자회 품목
    match /bazaarItems/{id} {
      allow read: if true;
      allow create, update: if signed()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 200;
      allow delete: if signed();
    }

    // 공지사항
    match /notices/{id} {
      allow read: if true;
      allow create, update: if signed()
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0 && request.resource.data.text.size() < 2000;
      allow delete: if signed();
    }

    // 팀 체크리스트 / 메모
    match /teams/{teamId}/checklists/{id} {
      allow read: if true;
      allow create, update: if signed()
        && request.resource.data.text is string && request.resource.data.text.size() < 300;
      allow delete: if signed();
    }
    match /teams/{teamId}/memos/{id} {
      allow read: if true;
      allow create: if signed()
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0 && request.resource.data.text.size() < 1000;
      allow delete: if signed();
    }

    // 지원 역할 (팀장 편집 — 역할명/담당자 추가·수정)
    match /supportRoles/{id} {
      allow read: if true;
      allow create, update: if signed()
        && request.resource.data.role is string
        && request.resource.data.role.size() > 0 && request.resource.data.role.size() < 100;
      allow delete: if signed();
    }

    // 한 줄 기도 방명록 (로그인 없이 누구나 작성 — 익명인증 + 스키마/길이 검증).
    //   create: 허용 키만 + text 1~150자 + by ≤40자 + amen 0 + 작성자uid·서버시각 고정
    //   update: '함께 기도'(amen) 필드 1개만 정확히 +1 (createdAt/by 등 변조·필드 주입 차단)
    //   delete: 편집모드(팀장/관리자)만 UI 노출 — 규칙은 인증자까지(1회용·신뢰그룹 모더레이션)
    match /guestPrayers/{id} {
      allow read: if true;
      allow create: if signed()
        && request.resource.data.keys().hasOnly(['text', 'by', 'amen', 'createdAt', 'createdByUid'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0 && request.resource.data.text.size() <= 150
        && request.resource.data.by is string && request.resource.data.by.size() <= 40
        && request.resource.data.amen == 0
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow update: if signed()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amen'])
        && request.resource.data.amen is number
        && request.resource.data.amen == resource.data.amen + 1;
      allow delete: if signed();
    }

    // 그 외 모든 경로 차단(명시되지 않음 = 기본 거부)
  }
}
